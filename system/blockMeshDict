	// vPPC vUPC (covered already)

	// vPPH vPPC (covered already)
	// vMPH vMPC (covered already)
	project vTPH vTPC (pOBDn) //(pBladeDn pOBDn) // make equivalent to one for next block that causes problems
	// vUPH vUPC (covered already)

	// edges of second blade BL block on min Q side
	// vMNH vPNH (covered already)
	project vTNH vUNH (hubnDn nOBDn)
	project vTNC vUNC (casingnDn nOBDn)
	// vMNC vPNC (covered already

	project vMNH vTNH (hubnDn nBladeDn)
	// vPNH vUNH (covered already)
	// vPNC vUNC (covered already)
	project vMNC vTNC (casingnDn nBladeDn)

	// vMNH vMNC (covered already)
	// vPNH vPNC (covered already)
	// vUNH vUNC (covered already)
	project vTNH vTNC (nOBDn) //(nBladeDn nOBDn) // this one is causing a problem; seems to work if I just do nOBDn

	// edges of downstream block
    // vUNH vUPH (covered already)
    project vUPH vOPH (hub pPerDn)
    project vOPH vONH (hub outlet)
    project vONH vUNH (hub nPerDn)

    // vUNC vUPC (covered already)
    project vUPC vOPC (casing pPerDn)
    project vOPC vONC (casing outlet)
    project vONC vUNC (casing nPerDn)
    
    // vUNH vUNC (covered already)
    // vUPH vUPC (covered already)
    project vOPH vOPC (pPerDn outlet)
    project vONH vONC (outlet nPerDn)

);

faces
(

	// face projections that are disabled (commented out) below are because putting them
	// in causes failure of periodic matching at a reasonable tolerance. They also aren't
	// technically needed to form a valid domain which conforms to the goemetry.
	// To consider commenting out:
	// upstream end of 1st pos-side BL block
	// upstream end of 1st neg-side BL block
	// downstream end of 2nd pos-side BL block
	// downstream end fo 2nd pos-side BL block
	// theta-normal(ish):
	// I-K pos and neg
	// U-O pos and neg

// axial-normal(ish) faces
	project (vINH vIPH vIPC vINC) inlet
//	project (vKPH vLPH vLPC vKPC) pOBUp // upstream end of 1st pos-side BL block
//	project (vLNH vKNH vKNC vLNC) nOBUp // upstream end of 1st neg-side BL block
	project (vKNH vKPH vKPC vKNC) LE
	project (vPNC vPNH vPPH vPPC) midChord
	project (vMPH vPPH vPPC vMPC) midChordHigh // between 2 pos-side BL blocks
	project (vPNH vMNH vMNC vPNC) midChordLow // between 2 neg-side BL blocks
	project (vUNH vUPH vUPC vUNC) TE
//	project (vUPH vTPH vTPC vUPC) pOBDn // downstream end of 2nd pos-side BL block
//	project (vTNH vUNH vUNC vTNC) nOBDn // downstream end of 2nd neg-side BL block
	project (vONH vOPH vOPC vONC) outlet

// theta-normal(ish) faces
	// pos side
    project (vIPH vKPH vKPC vIPC) pPerUp // I-K
    project (vKPH vPPH vPPC vKPC) pOffsetUp // K-P
    project (vPPH vUPH vUPC vPPC) pOffsetDn // P-U
    project (vLPH vMPH vMPC vLPC) pBladeUp // L-M
    project (vMPH vTPH vTPC vMPC) pBladeDn // M-T
    project (vUPH vOPH vOPC vUPC) pPerDn // U-O
    // neg side
    project (vINH vKNH vKNC vINC) nPerUp // I-K
    project (vKNH vPNH vPNC vKNC) nOffsetUp // K-P
    project (vPNH vUNH vUNC vPNC) nOffsetDn // P-U
    project (vLNH vMNH vMNC vLNC) nBladeUp // L-M
    project (vMNH vTNH vTNC vMNC) nBladeDn // M-T
    project (vUNH vONH vONC vUNC) nPerDn // U-O

// radial-normal(ish) faces
	// hub
    project (vINH vKNH vKPH vIPH) hub // I-K
    project (vKPH vPPH vMPH vLPH) hubpUp // BL 1 pos
    project (vPPH vUPH vTPH vMPH) hubpDn // BL 2 pos
    project (vKNH vPNH vPPH vKPH) hub // K-P
    project (vPNH vUNH vUPH vPPH) hub // P-U
    project (vLNH vMNH vPNH vKNH) hubnUp // BL 1 neg
    project (vMNH vTNH vUNH vPNH) hubnDn // BL 2 neg
    project (vUNH vONH vOPH vUPH) hub // U-O
    // casing
    project (vINC vKNC vKPC vIPC) casing // I-K
    project (vKPC vPPC vMPC vLPC) casingpUp // BL 1 pos
    project (vPPC vUPC vTPC vMPC) casingpDn // BL 2 pos
    project (vKNC vPNC vPPC vKPC) casing // K-P
    project (vPNC vUNC vUPC vPPC) casing // P-U
    project (vLNC vMNC vPNC vKNC) casingnUp // BL 1 neg
    project (vMNC vTNC vUNC vPNC) casingnDn // BL 2 neg
    project (vUNC vONC vOPC vUPC) casing // U-O

);

