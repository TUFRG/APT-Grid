// r = sqrt(x^2 + y^2)
// q = atan2(y,x)
// This definition means that when looking downstream (down the +ive z-axis),
// positive theta is CLOCKWISE

// Derived quantities: grading parameters

// Tuples are ( fraction of edge length  |  fraction of cells  |  grading )
// Use multiple tuples to split up edges into multiple segments

// Overall strategy:
// Each edge to be split into 2-3 parts.
// Radially: all blocks split the same way. 3 parts: hub BL, middle part, casing BL
// Tangentially: all blocks split the same way. 2 parts: lowTheta half, highTheta half
// 		(Note: for tangential, move cell distribution to uniform at domain inlet/outlet, but should
//		constrain this so that the variation isn't too large in cases where the inlet/outlet are
//		close to the LE/TE.)
// Axially: all blocks split into 2 parts: near LE/TE region and far from LE/TE region

// Since we are using 4 blocks only, the splits of the lengths are based on fractions. However, we
// can take advantage of the fact that blockMesh automatically normalizes the values given.
// So we need not actually compute the fractions directly. Instead, we can specify the length
// of the BL regions (delHub, delCas) and then look at the span at each edge to compute the
// middle parts (for radial grading). The tangential and axial grading are not based on the
// BLs, so instead do a split based on a distance from LE/TE that is some given fraction
// of the chord c (distance bewteen LE and TE points for each blade on hub and casing)
// then estimate block length (easy since can treat up-/down-stream extensions
// as straight lines and LE to TE as circular arc segment) to get other section length.

// Radial grading
	// Use known BL sizes + spans to determine grading parameters directly
	// (not a function of circumferential position,
	// so 8 edge sets needed, each used 2 times)
	// 4 segments to allow interior grading using nGrad parameter
radgradingI ($delHub $nBLcellsHub $gBLhub) (#eval{0.5*($spanI-$delHub-$delCas)} #eval{0.5*$nrad} $gRad) (#eval{0.5*($spanI-$delHub-$delCas)} #eval{0.5*$nrad} #eval{1.0/$gRad}) ($delCas $nBLcellsCas #eval{1/$gBLcas});
radgradingK ($delHub $nBLcellsHub $gBLhub) (#eval{0.5*($spanK-$delHub-$delCas)} #eval{0.5*$nrad} $gRad) (#eval{0.5*($spanK-$delHub-$delCas)} #eval{0.5*$nrad} #eval{1.0/$gRad}) ($delCas $nBLcellsCas #eval{1/$gBLcas});
radgradingL ($delHub $nBLcellsHub $gBLhub) (#eval{0.5*($spanL-$delHub-$delCas)} #eval{0.5*$nrad} $gRad) (#eval{0.5*($spanL-$delHub-$delCas)} #eval{0.5*$nrad} #eval{1.0/$gRad}) ($delCas $nBLcellsCas #eval{1/$gBLcas});
radgradingM ($delHub $nBLcellsHub $gBLhub) (#eval{0.5*($spanM-$delHub-$delCas)} #eval{0.5*$nrad} $gRad) (#eval{0.5*($spanM-$delHub-$delCas)} #eval{0.5*$nrad} #eval{1.0/$gRad}) ($delCas $nBLcellsCas #eval{1/$gBLcas});
radgradingP ($delHub $nBLcellsHub $gBLhub) (#eval{0.5*($spanP-$delHub-$delCas)} #eval{0.5*$nrad} $gRad) (#eval{0.5*($spanP-$delHub-$delCas)} #eval{0.5*$nrad} #eval{1.0/$gRad}) ($delCas $nBLcellsCas #eval{1/$gBLcas});
radgradingT ($delHub $nBLcellsHub $gBLhub) (#eval{0.5*($spanT-$delHub-$delCas)} #eval{0.5*$nrad} $gRad) (#eval{0.5*($spanT-$delHub-$delCas)} #eval{0.5*$nrad} #eval{1.0/$gRad}) ($delCas $nBLcellsCas #eval{1/$gBLcas});
radgradingU ($delHub $nBLcellsHub $gBLhub) (#eval{0.5*($spanU-$delHub-$delCas)} #eval{0.5*$nrad} $gRad) (#eval{0.5*($spanU-$delHub-$delCas)} #eval{0.5*$nrad} #eval{1.0/$gRad}) ($delCas $nBLcellsCas #eval{1/$gBLcas});
radgradingO ($delHub $nBLcellsHub $gBLhub) (#eval{0.5*($spanO-$delHub-$delCas)} #eval{0.5*$nrad} $gRad) (#eval{0.5*($spanO-$delHub-$delCas)} #eval{0.5*$nrad} #eval{1.0/$gRad}) ($delCas $nBLcellsCas #eval{1/$gBLcas});

// Tangential grading
	// Simpler, just 2 segments to allow symmetric variation in cell sizes
	// (7 edges needed: I(hub/cas)/L/M/T/O(hub/cas))
	// Move toward uniform spacing at I and O, but some constraint based
	// on length imposed.
tangradingIhub (0.5 0.5 $gTanIhub) (0.5 0.5 #eval{1/$gTanIhub});
tangradingIcas (0.5 0.5 $gTanIcas) (0.5 0.5 #eval{1/$gTanIcas});
tangradingL (0.5 0.5 $gTan) (0.5 0.5 #eval{1/$gTan});
tangradingM (0.5 0.5 $gTan) (0.5 0.5 #eval{1/$gTan});
tangradingT (0.5 0.5 $gTan) (0.5 0.5 #eval{1/$gTan});
tangradingOhub (0.5 0.5 $gTanOhub) (0.5 0.5 #eval{1/$gTanOhub});
tangradingOcas (0.5 0.5 $gTanOcas) (0.5 0.5 #eval{1/$gTanOcas});

// Axial grading
	// 2 segments per block edge, but each one must be computed individually.
	// So 16 edges needed: hub (H) and casing (C), positive (P) and
	// negative (N) theta, for each of the 4 blocks.
	//
	// For blocks 2 and 3, the values are used for both "axial" edges of the
	// blade BL blocks (the ones along the blade surface and the ones on the offset)
axgrading1HP (#eval{max($L1HP-0.5*$cHP,0)} #eval{1-$f1HPclo} $g1HPfar) (#eval{0.5*$cHP} $f1HPclo $g1HPclo);
axgrading1HN (#eval{max($L1HN-0.5*$cHN,0)} #eval{1-$f1HNclo} $g1HNfar) (#eval{0.5*$cHN} $f1HNclo $g1HNclo);
axgrading1CP (#eval{max($L1CP-0.5*$cCP,0)} #eval{1-$f1CPclo} $g1CPfar) (#eval{0.5*$cCP} $f1CPclo $g1CPclo);
axgrading1CN (#eval{max($L1CN-0.5*$cCN,0)} #eval{1-$f1CNclo} $g1CNfar) (#eval{0.5*$cCN} $f1CNclo $g1CNclo);

axgrading2HP (0.25 $fLEHP $gLEHP) (0.75 #eval{1-$fLEHP} $gM1HP);
axgrading2HN (0.25 $fLEHN $gLEHN) (0.75 #eval{1-$fLEHN} $gM1HN);
axgrading2CP (0.25 $fLECP $gLECP) (0.75 #eval{1-$fLECP} $gM1CP);
axgrading2CN (0.25 $fLECN $gLECN) (0.75 #eval{1-$fLECN} $gM1CN);

axgrading3HP (0.75 #eval{1-$fTEHP} $gM2HP) (0.25 $fTEHP $gTEHP);
axgrading3HN (0.75 #eval{1-$fTEHN} $gM2HN) (0.25 $fTEHN $gTEHN);
axgrading3CP (0.75 #eval{1-$fTECP} $gM2CP) (0.25 $fTECP $gTECP);
axgrading3CN (0.75 #eval{1-$fTECN} $gM2CN) (0.25 $fTECN $gTECN);

axgrading4HP (#eval{0.5*$cHP} $f4HPclo $g4HPclo) (#eval{max($L4HP-0.5*$cHP,0)} #eval{1-$f4HPclo} $g4HPfar); 
axgrading4HN (#eval{0.5*$cHN} $f4HNclo $g4HNclo) (#eval{max($L4HN-0.5*$cHN,0)} #eval{1-$f4HNclo} $g4HNfar); 
axgrading4CP (#eval{0.5*$cCP} $f4CPclo $g4CPclo) (#eval{max($L4CP-0.5*$cCP,0)} #eval{1-$f4CPclo} $g4CPfar); 
axgrading4CN (#eval{0.5*$cCN} $f4CNclo $g4CNclo) (#eval{max($L4CN-0.5*$cCN,0)} #eval{1-$f4CNclo} $g4CNfar); 

