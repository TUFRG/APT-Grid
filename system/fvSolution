FoamFile
{
    format      ascii;
    class       dictionary;
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    cellDisplacement
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-08;
        relTol          0;
        minIter			10;
    }

    p
    {
        solver          GAMG;
        smoother        symGaussSeidel;
        tolerance       1e-8;
        relTol          0.05; //0.1 = orig, 0.05 worked well
    }

    pFinal
    {
        $p;
        relTol          0;
    }

    "(rho|U|k|omega|epsilon)"
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-8;
        relTol          0.0;
    }

    UFinal
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-6;
        relTol          0;
    }

    kFinal
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-6;
        relTol          0;
    }

    omegaFinal
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-6;
        relTol          0;
    }

}
SIMPLE
{
	consistent yes;
    residualControl
    {
        p               1e-4; //e-4
        U               1e-4; //e-4
        "(k|omega|e)"   1e-4; //e-4
    }

    nNonOrthogonalCorrectors 3; // 3 = orig
}

PIMPLE
{
    nCorrectors              2;
    nNonOrthogonalCorrectors 1;
    nOuterCorrectors         1;
}

relaxationFactors
{
	fields
	{
		p 1;
	}
    equations
    {
		U 0.9;
		"(k|omega|epsilon)" 0.7;
    }
}

